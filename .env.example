# Database
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/rbq_app

# Redis
REDIS_URL=redis://localhost:6379

# Stripe (test keys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# CanLII API - Demander une clé via: https://www.canlii.org/en/info/feedback.html
CANLII_API_KEY=

# OPC Scraping
OPC_SCRAPING_DELAY=2.5

# Prix (en cents CAD)
PRIX_COMPLET=799
PRIX_PREMIUM=1299

# =============================================================================
# URLs des sources de données
# =============================================================================

# RBQ - Licences actives (JSON ~69Mo ou ZIP ~CSV)
RBQ_JSON_URL=https://www.donneesquebec.ca/recherche/dataset/755b45d6-7aee-46df-a216-748a0191c79f/resource/5183fdd4-55b1-418c-8a7d-0a70058ed68d/download/rdl01_extractiondonneesouvertes.json
RBQ_ZIP_URL=https://www.donneesquebec.ca/recherche/dataset/755b45d6-7aee-46df-a216-748a0191c79f/resource/32f6ec46-85fd-45e9-945b-965d9235840a/download/rdl01_extractiondonneesouvertes.zip

# REQ - Registre des entreprises (ZIP ~225Mo contenant 6 CSVs)
REQ_ZIP_URL=https://www.registreentreprises.gouv.qc.ca/RQAnonymeGR/GR/GR03/GR03A2_22A_PIU_RecupDonnPub_PC/FichierDonneesOuvertes.aspx

# SEAO - Appels d'offres publics (fichier JSON hebdomadaire le plus récent)
# Voir: https://www.donneesquebec.ca/recherche/dataset/systeme-electronique-dappel-doffres-seao
SEAO_URL=https://www.donneesquebec.ca/recherche/dataset/systeme-electronique-dappel-doffres-seao

# CNESST - Employeurs contrevenants (scraping)
CNESST_URL=https://www.cnesst.gouv.qc.ca/fr/salle-presse/employeurs-contrevenants

# OPC - Profil commerçant
OPC_SEARCH_URL=https://www.opc.gouv.qc.ca/consommateur/se-renseigner-sur-un-commercant/