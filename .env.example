# =============================================================================
# URLs des sources de données
# Note: donneesquebec.ca a expiré (avril 2026) - utiliser les miroirs
# =============================================================================

# RBQ — Miroir ouvert.canada.ca (fonctionnel)
RBQ_MIRROR_URL=https://ouvert.canada.ca/data/fr/dataset/755b45d6-7aee-46df-a216-748a0191c79f
# URLs directes (peuvent nécessiter Wayback Machine):
